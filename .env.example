# Пример переменных окружения для проекта CinemaWave
#
# На статическом сайте без бэкенда переменные окружения работают
# только при сборке (Vite, webpack и т.д.). Этот проект — чистый
# HTML/CSS/JS без сборки, поэтому ключ хранится в config.js.
#
# Если будешь использовать с бэкендом / сборщиком — скопируй файл:
#   cp .env.example .env
# и подставь свои значения.

KINOPOISK_API_KEY=ваш-ключ-сюда
